# 43 release-candidate example env for ATEL MCP
HOST=127.0.0.1
PORT=8787
ATEL_PLATFORM_BASE_URL=http://127.0.0.1:18210
ATEL_REGISTRY_BASE_URL=http://127.0.0.1:18210
ATEL_RELAY_BASE_URL=http://127.0.0.1:18210
ATEL_MCP_AUDIT_LOG_PATH=/root/.openclaw/deploy/atel-mcp/.runtime/audit/atel-mcp-rc.jsonl
ALLOW_CUSTOM_REMOTE_MCP=true
ATEL_MCP_DEFAULT_SCOPES=identity.read,wallet.read,contacts.read,messages.read,messages.write,orders.read,orders.write,milestones.read,milestones.write,disputes.read,disputes.write
ATEL_MCP_URL=http://127.0.0.1:8787/mcp
ATEL_MCP_BEARER_TOKEN=mcp-req-token
ATEL_MCP_REQUESTER_TOKEN=mcp-req-token
ATEL_MCP_EXECUTOR_TOKEN=mcp-exec-token
ATEL_MCP_EXECUTOR_DID=did:atel:ed25519:mcpexec
ATEL_MCP_CAPABILITY_TYPE=analysis.gold
ATEL_MCP_ARBITRATION_EXPECTED=passed
